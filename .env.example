# Obligatorio: Google Calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Opcional: único calendario a usar por nombre (prioritario sobre config/calendar*.yaml).
# Ejemplo: CALENDAR_NAME=Demo #hechoConIA
# CALENDAR_NAME=

# Opcional: tu email de Calendar (para --respond accept/decline si la API no devuelve 'self' en el evento).
# GOOGLE_CALENDAR_EMAIL=

# Opcional: Asana (dejar vacío si no usas Asana)
# ASANA_ACCESS_TOKEN=
# ASANA_WORKSPACE_GID=     # Workspace donde quieres listar tareas (ver CREDENTIALS.md)
# ASANA_INBOX_PROJECT_GID= # Proyecto "My Tasks" / inbox (opcional; ver CREDENTIALS.md)
# ASANA_USER_NAME=         # Tu nombre en Asana, para mostrar en el resumen (opcional)

# Opcional: Gmail usa el mismo OAuth de Google; no hace falta variable extra si añadiste scope Gmail en setup_oauth.py
